{
	"name": "pict-section-excalidraw",
	"version": "1.0.2",
	"description": "Pict view wrapping Excalidraw as an embeddable, themable, save/load-overridable drawing control",
	"main": "source/Pict-Section-Excalidraw.js",
	"files": [
		"source/",
		"vendor/excalidraw-built/",
		"scripts/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"start": "node source/Pict-Section-Excalidraw.js",
		"build": "npx quack build",
		"build:vendor": "node scripts/Build-Vendor-Bundles.js",
		"test": "mocha -u tdd -R spec",
		"tests": "mocha -u tdd -R spec -g",
		"test:e2e": "node test/puppeteer/Notebook-Generator-E2E.js",
		"generate-diagram": "node scripts/Generate-Notebook-Diagram.js",
		"coverage": "./node_modules/.bin/nyc --reporter=lcov --reporter=text-lcov ./node_modules/mocha/bin/_mocha -- -u tdd -R spec",
		"example": "npx quack examples"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fable-retold/pict-section-excalidraw.git"
	},
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/fable-retold/pict-section-excalidraw/issues"
	},
	"homepage": "https://github.com/fable-retold/pict-section-excalidraw#readme",
	"devDependencies": {
		"browser-env": "^3.3.0",
		"esbuild": "^0.19.10",
		"pict": "^1.0.372",
		"pict-docuserve": "^1.4.4",
		"puppeteer": "^24.43.1",
		"quackage": "^1.3.0"
	},
	"mocha": {
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "5000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		],
		"watch-ignore": [
			"vendor",
			"dist"
		]
	},
	"dependencies": {
		"chai": "^4.5.0",
		"pict-view": "^1.0.68"
	}
}
